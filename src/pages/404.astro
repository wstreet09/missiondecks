---
import BaseLayout from '../components/BaseLayout.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
---

<BaseLayout
  title="Page Not Found | Mission Decks & Design"
  description="The page you are looking for does not exist. Return to our homepage or contact us for help."
  noindex
>
  <Section bg="white">
    <Container width="narrow">
      <div class="text-center py-16">
        <h1 class="font-serif text-forest text-5xl lg:text-6xl mb-4">Page Not Found</h1>
        <p class="text-bark-light text-lg mb-8">
          The page you are looking for may have been moved or no longer exists. Let us help you find what you need.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <Button href="/" variant="primary">Back to Homepage</Button>
          <Button href="/contact/" variant="secondary">Contact Us</Button>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
