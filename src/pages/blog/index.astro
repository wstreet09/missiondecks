---
import BaseLayout from '../../components/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Container from '../../components/Container.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTASection from '../../components/CTASection.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<BaseLayout
  title="Blog | Mission Decks & Design"
  description="Tips on deck building, outdoor kitchens, pergolas & outdoor living from Mission Decks & Design in Holly Springs NC."
>
  <Section bg="white" padding="sm">
    <Container>
      <Breadcrumbs items={[{ label: 'Blog' }]} />
    </Container>
  </Section>

  <Section bg="white">
    <Container>
      <h1 class="font-serif text-forest text-4xl lg:text-5xl mb-4">Deck Building Tips & Outdoor Living Ideas</h1>
      <p class="text-bark-light text-lg mb-12 max-w-[600px]">Expert advice on deck construction, maintenance, materials, and outdoor living in the NC Triangle.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {posts.map(post => (
          <a href={`/blog/${post.id}/`} class="group block bg-white rounded-[8px] shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 no-underline overflow-hidden">
            {post.data.image && (
              <div class="overflow-hidden">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full aspect-[16/10] object-cover group-hover:scale-[1.03] transition-transform duration-300"
                  width="640"
                  height="400"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-6">
              <time class="text-bark-light text-sm">{new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <h2 class="font-serif text-forest text-xl lg:text-2xl mt-2 mb-2 group-hover:text-cedar transition-colors">{post.data.title}</h2>
              <p class="text-bark-light text-base leading-relaxed line-clamp-2">{post.data.description}</p>
              <span class="inline-flex items-center text-cedar font-medium text-[0.9375rem] mt-3 group-hover:gap-2 gap-1 transition-all duration-200">
                Read More <span class="transition-transform duration-200 group-hover:translate-x-1">&rarr;</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </Section>

  <CTASection />
</BaseLayout>
