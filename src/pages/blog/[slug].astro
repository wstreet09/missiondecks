---
import BaseLayout from '../../components/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Container from '../../components/Container.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaMarkup from '../../components/SchemaMarkup.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | Mission Decks & Design`}
  description={post.data.description}
  ogType="article"
  ogImage={post.data.image}
>
  <SchemaMarkup slot="schema" type="Article" data={{
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate,
    author: {
      '@type': 'Organization',
      name: post.data.author,
    },
    image: post.data.image,
  }} />

  <Section bg="white" padding="sm">
    <Container>
      <Breadcrumbs items={[
        { label: 'Blog', href: '/blog/' },
        { label: post.data.title },
      ]} />
    </Container>
  </Section>

  <Section bg="white">
    <Container width="narrow">
      <article>
        <header class="mb-10">
          <time class="text-bark-light text-sm">
            {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <h1 class="font-serif text-forest text-3xl lg:text-[2.75rem] leading-[1.15] mt-2 mb-4">{post.data.title}</h1>
          <p class="text-bark-light text-lg">{post.data.description}</p>
          {post.data.image && (
            <img
              src={post.data.image}
              alt={post.data.title}
              class="w-full aspect-[16/9] object-cover rounded-[8px] mt-6"
              width="720"
              height="405"
              loading="eager"
            />
          )}
        </header>

        <div class="prose prose-lg max-w-none
          [&_h2]:font-serif [&_h2]:text-forest [&_h2]:text-2xl [&_h2]:lg:text-3xl [&_h2]:mt-10 [&_h2]:mb-4
          [&_h3]:font-sans [&_h3]:text-forest [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3
          [&_p]:text-bark [&_p]:leading-relaxed [&_p]:mb-4
          [&_ul]:text-bark [&_ul]:space-y-2 [&_ul]:mb-6 [&_ul]:list-disc [&_ul]:pl-6
          [&_li]:text-bark [&_li]:leading-relaxed
          [&_strong]:text-bark [&_strong]:font-semibold
          [&_a]:text-cedar [&_a]:no-underline [&_a]:hover:text-cedar-light
          [&_table]:w-full [&_table]:border-collapse [&_table]:my-6
          [&_th]:bg-stone [&_th]:text-forest [&_th]:text-left [&_th]:p-3 [&_th]:text-sm [&_th]:font-semibold
          [&_td]:border-b [&_td]:border-border [&_td]:p-3 [&_td]:text-sm [&_td]:text-bark
          [&_hr]:border-border [&_hr]:my-10
        ">
          <Content />
        </div>

        {post.data.tags.length > 0 && (
          <div class="mt-10 pt-6 border-t border-border flex flex-wrap gap-2">
            {post.data.tags.map(tag => (
              <span class="inline-block bg-stone text-bark-light text-xs font-medium px-3 py-1 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}
      </article>
    </Container>
  </Section>

  <CTASection />
</BaseLayout>
