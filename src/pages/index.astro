---
import BaseLayout from '../components/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import ServiceCard from '../components/ServiceCard.astro';
import LocationCard from '../components/LocationCard.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTASection from '../components/CTASection.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import Button from '../components/Button.astro';
import { site } from '../data/site';
import { services } from '../data/services';
import { locations } from '../data/locations';

const process = [
  { step: 1, title: 'Design Consultation', description: 'We visit your home, discuss your vision, and walk through material and layout options in person.' },
  { step: 2, title: 'Custom Proposal', description: 'You receive a detailed, line-item proposal with 3D renderings tailored to your space.' },
  { step: 3, title: 'Expert Build', description: 'Our crew builds on-site with daily communication, clean workmanship, and meticulous attention to detail.' },
  { step: 4, title: 'Final Walkthrough', description: 'We inspect every detail together and ensure the finished result exceeds your expectations.' },
];

const serviceOverlines = ['FLAGSHIP SERVICE', 'OUTDOOR ENTERTAINING', 'SHADE & STRUCTURE', 'AMBIANCE & SAFETY', 'PRIVACY & STYLE', 'YEAR-ROUND COMFORT'];
---

<BaseLayout
  title="Mission Decks & Design | Premium Custom Deck Builder in Holly Springs NC"
  description="Premium custom decks, outdoor kitchens, pergolas & complete outdoor living transformations in Holly Springs, Apex, Cary & the NC Triangle. Request a consultation from Mission Decks & Design."
>
  <SchemaMarkup slot="schema" type="LocalBusiness" />

  <HeroSection
    overline="PREMIUM DECK BUILDING · HOLLY SPRINGS, NC"
    heading="Custom Deck Builder in Holly Springs"
    subtitle="We design and build premium custom decks, outdoor kitchens, and complete backyard transformations — tailored to your home, your lifestyle, and the way your family lives."
    buttonText="Schedule a Consultation"
    buttonHref="/contact/"
    secondaryButtonText="View Our Work"
    secondaryButtonHref="/services/"
    image="/images/hero/aerial-deck-porch.jpeg"
    imageAlt="Premium custom composite deck and screened porch by Mission Decks & Design in Holly Springs NC"
  />

  <!-- Services -->
  <Section bg="white" padding="lg">
    <Container>
      <div class="text-center mb-14">
        <span class="overline">WHAT WE BUILD</span>
        <h2 class="font-serif text-forest text-3xl lg:text-[3rem] mb-3">Premium Outdoor Living Services</h2>
        <div class="gold-line-center mt-4 mb-6"></div>
        <p class="text-bark-light text-lg font-light max-w-[600px] mx-auto">Every project is thoughtfully designed around your space and crafted with materials chosen to endure.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service, i) => (
          <ServiceCard
            name={service.name}
            description={service.shortDescription}
            href={`/services/${service.slug}/`}
            image={service.image}
            overline={serviceOverlines[i]}
          />
        ))}
      </div>
      <div class="text-center mt-12">
        <Button href="/services/" variant="gold">Explore All Services</Button>
      </div>
    </Container>
  </Section>

  <!-- Why Mission Decks -->
  <Section bg="stone" padding="lg">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
        <div>
          <span class="overline">WHY MISSION DECKS</span>
          <h2 class="font-serif text-forest text-3xl lg:text-[3rem] leading-tight mb-6">Where Design Meets Craftsmanship</h2>
          <div class="gold-line mb-8"></div>
          <div class="space-y-5 text-bark font-light">
            <p>We are a Holly Springs-based, owner-led outdoor living studio that handles both the creative design and the structural precision of every project. You work directly with the people who understand Triangle-area homes, neighborhoods, soil conditions, and building codes.</p>
            <p>Every deck, porch, and outdoor kitchen we build starts with a conversation about how you actually use your space — not a template. We provide detailed, transparent proposals, realistic timelines with consistent communication, and craftsmanship that endures decades of North Carolina weather.</p>
          </div>
          <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex items-start gap-3">
              <span class="text-gold font-bold text-base mt-0.5">&#10003;</span>
              <span class="text-bark text-[0.9375rem]">Bespoke designs tailored to your home</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-gold font-bold text-base mt-0.5">&#10003;</span>
              <span class="text-bark text-[0.9375rem]">Owner-led from design to final walkthrough</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-gold font-bold text-base mt-0.5">&#10003;</span>
              <span class="text-bark text-[0.9375rem]">Transparent estimates with no hidden costs</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-gold font-bold text-base mt-0.5">&#10003;</span>
              <span class="text-bark text-[0.9375rem]">Complete outdoor transformations, one trusted partner</span>
            </div>
          </div>
        </div>
        <div>
          <img
            src="/images/areas/deck-screened-porch-combo.jpg"
            alt="Custom deck and screened porch transformation by Mission Decks & Design"
            class="rounded-[8px] w-full object-cover shadow-lg"
            style="aspect-ratio: 4/5; max-height: 600px;"
            width="720"
            height="900"
            loading="lazy"
          />
        </div>
      </div>
    </Container>
  </Section>

  <!-- Project Gallery -->
  <Section bg="white" padding="lg">
    <Container>
      <div class="text-center mb-14">
        <span class="overline">OUR PORTFOLIO</span>
        <h2 class="font-serif text-forest text-3xl lg:text-[3rem] mb-3">Recent Transformations</h2>
        <div class="gold-line-center mt-4 mb-6"></div>
        <p class="text-bark-light text-lg font-light max-w-[600px] mx-auto">A selection of custom builds across Holly Springs, Cary, Apex, and the Triangle.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        <img
          src="/images/hero/composite-deck-screened-porch.jpeg"
          alt="New composite deck with screened porch and black railing in Holly Springs NC"
          class="rounded-[6px] w-full aspect-[4/3] object-cover"
          width="480" height="360" loading="lazy"
        />
        <img
          src="/images/areas/deck-railing-stairs-porch.jpeg"
          alt="Custom deck with metal railing and stairs leading to screened porch"
          class="rounded-[6px] w-full aspect-[4/3] object-cover"
          width="480" height="360" loading="lazy"
        />
        <img
          src="/images/services/pergola-pool-daytime.jpeg"
          alt="Cedar pergola with outdoor seating area next to pool"
          class="rounded-[6px] w-full aspect-[4/3] object-cover"
          width="480" height="360" loading="lazy"
        />
        <img
          src="/images/blog/deck-exterior-black-railing.jpeg"
          alt="Composite deck with black aluminum railing on residential home"
          class="rounded-[6px] w-full aspect-[4/3] object-cover"
          width="480" height="360" loading="lazy"
        />
        <img
          src="/images/services/screened-porch-horizontal-skirting.jpeg"
          alt="Screened porch with horizontal composite skirting and lattice detail"
          class="rounded-[6px] w-full aspect-[4/3] object-cover"
          width="480" height="360" loading="lazy"
        />
        <img
          src="/images/blog/gray-composite-deck-platform.jpeg"
          alt="Gray composite deck platform with step-down design"
          class="rounded-[6px] w-full aspect-[4/3] object-cover"
          width="480" height="360" loading="lazy"
        />
      </div>
      <div class="text-center mt-12">
        <Button href="/contact/" variant="gold">Start Your Project</Button>
      </div>
    </Container>
  </Section>

  <!-- Process -->
  <Section bg="stone" padding="lg">
    <Container>
      <ProcessSteps steps={process} heading="From Vision to Reality" overline="OUR PROCESS" />
    </Container>
  </Section>

  <!-- Service Areas -->
  <Section bg="white" padding="lg">
    <Container>
      <div class="text-center mb-14">
        <span class="overline">SERVICE AREAS</span>
        <h2 class="font-serif text-forest text-3xl lg:text-[3rem] mb-3">Serving the NC Triangle</h2>
        <div class="gold-line-center mt-4 mb-6"></div>
        <p class="text-bark-light text-lg font-light max-w-[600px] mx-auto">Premium custom outdoor living spaces across Holly Springs and the surrounding Triangle communities.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {locations.map(location => (
          <LocationCard
            name={location.name}
            neighborhoods={location.neighborhoods}
            href={`/service-areas/${location.slug}/`}
          />
        ))}
      </div>
    </Container>
  </Section>

  <!-- Testimonial -->
  <Section bg="stone" padding="lg">
    <Container>
      <div class="text-center mb-12">
        <span class="overline">CLIENT EXPERIENCES</span>
        <h2 class="font-serif text-forest text-3xl lg:text-[3rem] mb-3">What Our Clients Say</h2>
        <div class="gold-line-center mt-4"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-[900px] mx-auto">
        <TestimonialBlock
          quote="They rebuilt our entire deck in 12 Oaks and it looks like it was always part of the house. The HOA approved it in one pass because Mission Decks prepared everything perfectly."
          name="The Andersons"
          location="12 Oaks, Holly Springs"
        />
        <TestimonialBlock
          quote="We had three contractors say our MacGregor Downs lot was too complicated. Mission Decks designed around every constraint and the result is stunning."
          name="Robert & Linda K."
          location="MacGregor Downs, Cary"
        />
      </div>
    </Container>
  </Section>

  <CTASection />
</BaseLayout>
