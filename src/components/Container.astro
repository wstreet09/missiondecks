---
interface Props {
  width?: 'content' | 'narrow' | 'wide';
  class?: string;
}

const { width = 'content', class: className = '' } = Astro.props;

const maxWidths = {
  content: 'max-w-[1200px]',
  narrow: 'max-w-[720px]',
  wide: 'max-w-[1440px]',
};
---

<div class:list={['mx-auto px-4 sm:px-6 lg:px-8', maxWidths[width], className]}>
  <slot />
</div>
