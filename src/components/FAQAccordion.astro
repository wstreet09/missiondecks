---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
  heading?: string;
}

const { faqs, heading = 'Frequently Asked Questions' } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<div>
  {heading && <h2 class="font-serif text-forest text-3xl lg:text-4xl mb-8">{heading}</h2>}
  <div class="space-y-3">
    {faqs.map((faq, index) => (
      <details class="group bg-white border border-border rounded-[8px] overflow-hidden">
        <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-bark font-medium text-base lg:text-lg hover:text-forest transition-colors list-none [&::-webkit-details-marker]:hidden">
          <span class="pr-4">{faq.question}</span>
          <svg class="w-5 h-5 shrink-0 text-bark-light transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-6 pb-5 text-bark-light leading-relaxed text-base">
          {faq.answer}
        </div>
      </details>
    ))}
  </div>
</div>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
